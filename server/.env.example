# ── Vercel Postgres (Neon) ──────────────────────────────────────────
# 连接池地址（日常查询用）
# 由 Vercel 控制台 Storage → Connect to Project 自动注入，或本地运行 `vercel env pull .env.local` 获取
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"

# 直连地址（prisma migrate / prisma db push 用，不经过连接池）
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ── Vercel Blob ─────────────────────────────────────────────────────
# 由 Vercel 控制台 Storage → Connect to Project 自动注入
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# ── JWT ─────────────────────────────────────────────────────────────
# 生产环境必须替换为足够长的随机字符串
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRES_IN="30d"

# ── 短信服务（阿里云）──────────────────────────────────────────────
# 开发模式下留空，验证码会打印到终端
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME="养西瓜"
ALIYUN_SMS_TEMPLATE_CODE="SMS_xxxxxx"

# 环境
NODE_ENV="development"
