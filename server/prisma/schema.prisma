// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── 用户 ───────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  childName String   @default("")
  circleId  String?

  circle    Circle?    @relation("CircleMembers", fields: [circleId], references: [id])
  pet       Pet?
  taskLogs  TaskLog[]
  userTasks UserTask[]
  cheersGiven    Cheer[] @relation("CheersGiven")
  cheersReceived Cheer[] @relation("CheersReceived")

  createdAt DateTime @default(now())

  @@map("users")
}

// ── 宠物 ───────────────────────────────────────────────────────
model Pet {
  id           String    @id @default(cuid())
  ownerId      String    @unique
  owner        User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name         String
  species      String    // cat | dog | rabbit | dragon | hamster
  level        Int       @default(1)
  totalPoints  Int       @default(0)        // 历史累计总积分，不重置
  currentCyclePoints Int @default(0)        // 当前周期积分，兑换后重置
  harvestCount Int       @default(0)        // 历史兑换次数
  lastFedAt    DateTime?
  hungerStatus String    @default("normal") // happy|normal|hungry|starving|critical

  harvests     HarvestRecord[]

  createdAt    DateTime  @default(now())

  @@map("pets")
}

// ── 兑换记录（工作人员手动确认是否已寄出真西瓜）──────────
model HarvestRecord {
  id          String   @id @default(cuid())
  petId       String
  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  cycleNumber Int                   // 第几季收成
  pointsAtHarvest Int               // 收成时累计周期积分
  redeemedAt  DateTime              // 孩子发起兑换的时间
  shippedAt   DateTime?             // 工作人员标记已寄出的时间（null = 未发货）
  note        String?               // 工作人员备注（如快递单号）

  @@index([petId])
  @@map("harvest_records")
}

// ── 任务记录 ──────────────────────────────────────────────────
model TaskLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskType        String   // reading|piano|english|preview|homework|exercise|custom
  taskName        String
  durationMinutes Int      @default(0)
  points          Int
  completed       Boolean  @default(true)
  date            String   // YYYY-MM-DD，方便按天聚合

  evidenceUrl     String?  // Vercel Blob URL（图片、音频或视频）
  evidenceType    String?  // "image" | "audio" | "video"
  confirmed       Boolean  @default(false) // 家长是否已确认

  createdAt       DateTime @default(now())

  @@index([userId, date])
  @@map("task_logs")
}

// ── 圈子 ──────────────────────────────────────────────────────
model Circle {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique
  creatorId  String

  members    User[]   @relation("CircleMembers")

  createdAt  DateTime @default(now())

  @@map("circles")
}

// ── 全局任务模板 ──────────────────────────────────────────────
model TaskTemplate {
  id             String     @id @default(cuid())
  key            String     @unique  // reading|piano|english|preview|homework|exercise|custom
  name           String
  emoji          String
  colorHex       String
  pointsPer15Min Int
  isTimeBased    Boolean    @default(true)
  evidenceTypes  String[]                     // ["image", "audio"]
  sortOrder      Int        @default(0)
  isActive       Boolean    @default(true)
  isDefault      Boolean    @default(false) // 新用户自动添加

  userTasks      UserTask[]

  @@map("task_templates")
}

// ── 用户已启用任务 ────────────────────────────────────────────
model UserTask {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String
  template   TaskTemplate @relation(fields: [templateId], references: [id])

  createdAt  DateTime     @default(now())

  @@unique([userId, templateId])
  @@index([userId])
  @@map("user_tasks")
}

// ── 短信验证码 ────────────────────────────────────────────────
model SmsCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([phone])
  @@map("sms_codes")
}

// ── 加油记录 ──────────────────────────────────────────────────
// 每人每天对同一目标最多加油一次（fromUserId + toUserId + date 唯一）
model Cheer {
  id         String    @id @default(cuid())
  fromUserId String
  fromUser   User      @relation("CheersGiven",    fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User      @relation("CheersReceived", fields: [toUserId],   references: [id], onDelete: Cascade)
  date       String    // YYYY-MM-DD，同一天同一对只能一次
  readAt     DateTime? // 收件人点"知道了"后写入，null = 未读

  createdAt  DateTime @default(now())

  @@unique([fromUserId, toUserId, date])
  @@index([toUserId, date])
  @@map("cheers")
}
